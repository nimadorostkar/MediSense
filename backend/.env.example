# ─────────────────────────────────────────────────────────────────────────────
# MediSense backend environment — copy to .env and adjust.
# ─────────────────────────────────────────────────────────────────────────────

# Datastore. Defaults to a local SQLite file so the slice runs with zero setup.
# Production target (matches the spec): PostgreSQL + pgvector via docker-compose.
#   postgresql+asyncpg://medisense:medisense@localhost:5432/medisense
DATABASE_URL=sqlite+aiosqlite:///./medisense.db

# Redis cache (optional in the pilot; engine works without it).
# REDIS_URL=redis://localhost:6379/0

# Optional: real LLM reasoning polish for the `because`/treatment narrative.
# Without a key the engine still produces a full differential + treatment from
# retrieval + rules (deterministic fallback), so nothing breaks.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# CORS — where the Vite dev frontend runs.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# API server port.
PORT=8787
