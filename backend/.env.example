# ─────────────────────────────────────────────────────────────────────────────
# MediSense backend environment — copy to `.env` and fill in.
# Secrets come from the environment, NEVER from code (spec §1.8 / §18.1).
# ─────────────────────────────────────────────────────────────────────────────

# ── Datastore ────────────────────────────────────────────────────────────────
# Postgres + pgvector in production; omit for the zero-setup SQLite dev fallback.
# Async drivers: postgresql+asyncpg://...  or  sqlite+aiosqlite:///./medisense.db
# DATABASE_URL=postgresql+asyncpg://medisense:medisense@postgres:5432/medisense
DATABASE_URL=sqlite+aiosqlite:///./medisense.db

# Optional Redis (per-encounter context cache + triage/vitals pub-sub). Off if unset.
# REDIS_URL=redis://redis:6379/0

# Configurable data residency / region (spec §18.1, §21).
DATA_REGION=cn-pilot

# ── Zhipu GLM (reasoning) + Zhipu embeddings (RAG) ───────────────────────────
# China base URL; international endpoint is swappable. Verify current model ids
# against Zhipu docs at build time and update the defaults if they changed.
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_CHAT_MODEL=glm-4.6
EMBEDDING_MODEL=embedding-3
# Master flag for the grounded, citation-required GLM reasoning layer. Off by
# default so the deterministic hybrid pipeline is what ships first (spec §12.5).
LLM_REASONING=false
# Bounded token/cost budget for a single reasoning call.
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=12

# ── Auth (OIDC/OAuth2 + RBAC) ────────────────────────────────────────────────
# DEV_AUTH=true accepts a locally-signed dev token so the stack runs without the
# hospital IdP. Set false in production and configure the real OIDC validation.
DEV_AUTH=true
DEV_AUTH_SECRET=dev-only-change-me
OIDC_ISSUER=
OIDC_AUDIENCE=medisense
OIDC_JWKS_URL=

# ── HTTP / CORS ──────────────────────────────────────────────────────────────
# Comma-separated allowlist for the React UI origin(s).
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8787
RATE_LIMIT_PER_MINUTE=120

# ── Version stamps (semantic; stamped onto every response — spec §3.5/§14.2) ──
MODEL_VERSION=dx-2026.06.1-pilot
RULESET_VERSION=rules-2026.06.1
DRUGREF_VERSION=drugref-2026.06.1
PROMPT_VERSION=prompt-2026.06.1

# ── Integration (hospital HIS / FHIR write-back) ─────────────────────────────
# Mock adapter by default; point at a FHIR sandbox/base to exercise the real path.
FHIR_BASE_URL=
FHIR_WRITE_BACK=false

# ── Engine tuning ────────────────────────────────────────────────────────────
RETRIEVAL_K=8
OOD_SIMILARITY_FLOOR=0.28
LOG_LEVEL=INFO
