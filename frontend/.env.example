# ─────────────────────────────────────────────────────────────────────────────
# MediSense environment
# ─────────────────────────────────────────────────────────────────────────────
# The Anthropic API key is used ONLY by the server (server/index.js). It must
# never be exposed to the browser. Copy this file to `.env` and fill it in.

# Server-side only — required to get real clinical reasoning.
ANTHROPIC_API_KEY=
# Model used by the server route.
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Port the API server listens on.
PORT=8787

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# Where the browser posts conversations. Defaults to /api/clinical (proxied to
# the server in dev). Only set this if your API lives elsewhere.
# VITE_API_URL=/api/clinical

# Dev-only: where Vite proxies /api to. Defaults to http://localhost:8787
# VITE_PROXY_TARGET=http://localhost:8787
