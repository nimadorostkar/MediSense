# ─────────────────────────────────────────────────────────────────────────────
# MediSense frontend environment — copy to `.env`
# ─────────────────────────────────────────────────────────────────────────────
# The frontend talks to the FastAPI backend (../backend) — there is NO Node/
# Anthropic server anymore. Only VITE_* vars are read by the browser bundle.

# ── Dev ──────────────────────────────────────────────────────────────────────
# Where Vite proxies /api/* in dev (so the browser can post to /api/clinical
# without CORS). Defaults to http://localhost:8787.
VITE_PROXY_TARGET=http://localhost:8787

# ── Production ────────────────────────────────────────────────────────────────
# In a built bundle there is no dev proxy. Point the app at the backend's
# absolute URL (and allow this origin in the backend's CORS_ORIGINS), e.g.:
#   VITE_API_URL=https://api.medisense.example/api/clinical
# OR leave it unset and serve the built dist/ behind the SAME origin as the
# backend via a reverse proxy (recommended — keeps /api/* same-origin).
# VITE_API_URL=/api/clinical

# ── Safety: offline demo stub ────────────────────────────────────────────────
# The offline demo stub is DISABLED by default. It can ONLY be enabled in a dev
# build (never in production) and will fabricate placeholder clinical text when
# the backend is unreachable — for UI demos only. Leave unset for real use.
# VITE_ALLOW_OFFLINE_STUB=true
